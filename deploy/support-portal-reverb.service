[Unit]
Description=Support Portal Laravel Reverb
After=network.target

[Service]
WorkingDirectory=/mnt/hgfs/Portal/MIS-Portal-main/support-portal-web1
ExecStart=/usr/bin/php artisan reverb:start --host=0.0.0.0 --port=8081 --no-interaction
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
